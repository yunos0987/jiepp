///{#include './boost/preprocessor/config/config.hpp'}















function add_int_2: int var_input     in1: int; in2: int; end_var (*{st}*) add_int_2 :=  in1 + in2; (*{end}*) end_function function add_int_3: int var_input     in1: int; in2: int; in3: int; end_var (*{st}*) add_int_3 :=  in1 + in2 + in3; (*{end}*) end_function function add_int_4: int var_input     in1: int; in2: int; in3: int; in4: int; end_var (*{st}*) add_int_4 :=  in1 + in2 + in3 + in4; (*{end}*) end_function function add_int_5: int var_input     in1: int; in2: int; in3: int; in4: int; in5: int; end_var (*{st}*) add_int_5 :=  in1 + in2 + in3 + in4 + in5; (*{end}*) end_function function add_int_6: int var_input     in1: int; in2: int; in3: int; in4: int; in5: int; in6: int; end_var (*{st}*) add_int_6 :=  in1 + in2 + in3 + in4 + in5 + in6; (*{end}*) end_function function add_int_7: int var_input     in1: int; in2: int; in3: int; in4: int; in5: int; in6: int; in7: int; end_var (*{st}*) add_int_7 :=  in1 + in2 + in3 + in4 + in5 + in6 + in7; (*{end}*) end_function function add_int_8: int var_input     in1: int; in2: int; in3: int; in4: int; in5: int; in6: int; in7: int; in8: int; end_var (*{st}*) add_int_8 :=  in1 + in2 + in3 + in4 + in5 + in6 + in7 + in8; (*{end}*) end_function function add_int_9: int var_input     in1: int; in2: int; in3: int; in4: int; in5: int; in6: int; in7: int; in8: int; in9: int; end_var (*{st}*) add_int_9 :=  in1 + in2 + in3 + in4 + in5 + in6 + in7 + in8 + in9; (*{end}*) end_function



