// JIEPP_DIRECTIVE_TOKEN(name, value)
JIEPP_DIRECTIVE_TOKEN(IFDEF,                  MASK_CTRLEX   |  1)
JIEPP_DIRECTIVE_TOKEN(IFNDEF,                 MASK_CTRLEX   |  2)
JIEPP_DIRECTIVE_TOKEN(IF,                     MASK_CTRL     |  1)
JIEPP_DIRECTIVE_TOKEN(ELIF,                   MASK_CTRL     |  2)
JIEPP_DIRECTIVE_TOKEN(ELSE,                   MASK_CTRL     |  3)
JIEPP_DIRECTIVE_TOKEN(ENDIF,                  MASK_CTRL     |  4)
JIEPP_DIRECTIVE_TOKEN(INCLUDE,                MASK_INCLUDE  |  1)
JIEPP_DIRECTIVE_TOKEN(SINCLUDE,               MASK_INCLUDE  |  2)
JIEPP_DIRECTIVE_TOKEN(SEVERE,                 MASK_MESSAGE  |  1)
JIEPP_DIRECTIVE_TOKEN(ERROR,                  MASK_MESSAGE  |  2)
JIEPP_DIRECTIVE_TOKEN(WARNING,                MASK_MESSAGE  |  3)
JIEPP_DIRECTIVE_TOKEN(INFO,                   MASK_MESSAGE  |  4)
JIEPP_DIRECTIVE_TOKEN(STRING,                 MASK_STRINGIZE | 1)
JIEPP_DIRECTIVE_TOKEN(WSTRING,                MASK_STRINGIZE | 2)
JIEPP_DIRECTIVE_TOKEN(DEFINE,                 1)
JIEPP_DIRECTIVE_TOKEN(UNDEF,                  2)
JIEPP_DIRECTIVE_TOKEN(TOKENIZE,               3)
JIEPP_DIRECTIVE_TOKEN(SETLINE,                4)
JIEPP_DIRECTIVE_TOKEN(SYSPATH,                5)
JIEPP_DIRECTIVE_TOKEN(IGNORE,                 6)
JIEPP_DIRECTIVE_TOKEN(NOP,                    7)
JIEPP_DIRECTIVE_TOKEN(MAX_INCLUDE_DEPTH,      8)
JIEPP_DIRECTIVE_TOKEN(PP_OUTPUT_PRAGMA_STYLE, 9)
JIEPP_DIRECTIVE_TOKEN(MAX_EXPANSION_DEPTH,   11)
JIEPP_DIRECTIVE_TOKEN(MAX_IF_NESTING,        12)
