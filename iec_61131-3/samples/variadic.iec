(* variadic.iec - __VA_ARGS__ and __VA_ARGC__ *)

{#define PRINT(...) print(__VA_ARGS__)}
{#define COUNT(...) __VA_ARGC__}
{#define FIRST(a, ...) a}
{#define REST(a, ...) __VA_ARGS__}

program Main
var
    n: int;
end_var
{st}
PRINT(1, 2, 3);
n := COUNT(a, b, c);
n := FIRST(10, 20, 30);
PRINT(REST(1, 2, 3));
{end}
end_program
